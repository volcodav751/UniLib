@inject NavigationManager Navigation

<div class="landing-column">
    <div class="backgroundpanel">
        <div class="panel-title-row">
            <span class="panel-icon">🔎</span>
            <h2>Catalog</h2>
            
        </div>

        <div class="pill-list">
            <button class="pill-button" @onclick='() => Navigation.NavigateTo("/catalog")'>
                <span>📘 Browse Books</span>
                <span>50K+</span>
            </button>

            <button class="pill-button" @onclick='() => Navigation.NavigateTo("/catalog")'>
                <span>📄 Journals</span>
                <span>25K+</span>
            </button>

            <button class="pill-button" @onclick='() => Navigation.NavigateTo("/catalog")'>
                <span>🗂 Archives</span>
                <span>10K+</span>
            </button>
        </div>
    </div>

    <div class="backgroundpanel">
        <div class="search-box">
            <span class="search-box__icon">🔍</span>
            <input placeholder="Search catalog..." @onfocus='() => Navigation.NavigateTo("/catalog")' />
        </div>
    </div>
</div>