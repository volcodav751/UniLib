@using UniLibrary.Blazor.Models
@using System.IO

<div class="catalog-sidebar">
    <div class="sidebar-section">
        <div class="panel-title-row">
            <span class="panel-icon">🔎</span>
            <h3>Пошук</h3>
        </div>

        <div class="search-box">
            <span class="search-box__icon">🔍</span>
            <input placeholder="Назва, автор, ISBN або тег..." value="@Filters.SearchQuery" @oninput="OnSearchChanged" />
        </div>
    </div>

    @if (Filters.HasAnyActiveFilter)
    {
        <div class="sidebar-section sidebar-section--compact">
            <button class="filter-reset-button" @onclick="ResetFilters">
                Скинути всі фільтри
            </button>
        </div>
    }

    @if (FormatOptions.Count > 0)
    {
        <div class="sidebar-section">
            <div class="panel-title-row">
                <span class="panel-icon">📄</span>
                <h3>Формат файлу</h3>
            </div>

            <div class="sidebar-list">
                @foreach (var format in FormatOptions)
                {
                    <button class="filter-pill @(Filters.SelectedFormats.Contains(format.Value) ? "filter-pill--active" : "")"
                            @onclick="@(() => ToggleFormat(format.Value))">
                        <span>@format.Value</span>
                        <span>@format.Count</span>
                    </button>
                }
            </div>
        </div>
    }

    @if (CategoryOptions.Count > 0)
    {
        <div class="sidebar-section">
            <h3>Категорія</h3>
            <div class="sidebar-list">
                @foreach (var category in CategoryOptions)
                {
                    <button class="filter-pill @(Filters.SelectedCategories.Contains(category.Value) ? "filter-pill--active" : "")"
                            @onclick="@(() => ToggleCategory(category.Value))">
                        <span>@category.Value</span>
                        <span>@category.Count</span>
                    </button>
                }
            </div>
        </div>
    }

    @if (LanguageOptions.Count > 0)
    {
        <div class="sidebar-section">
            <h3>Мова</h3>
            <div class="sidebar-list">
                @foreach (var language in LanguageOptions)
                {
                    <button class="filter-pill @(Filters.SelectedLanguages.Contains(language.Value) ? "filter-pill--active" : "")"
                            @onclick="@(() => ToggleLanguage(language.Value))">
                        <span>@language.Value</span>
                        <span>@language.Count</span>
                    </button>
                }
            </div>
        </div>
    }

    @if (YearOptions.Count > 0)
    {
        <div class="sidebar-section">
            <h3>Рік публікації</h3>
            <div class="chips-wrap">
                @foreach (var year in YearOptions)
                {
                    <button class="chip @(Filters.SelectedYears.Contains(year) ? "chip--active" : "")"
                            @onclick="@(() => ToggleYear(year))">
                        @year
                    </button>
                }
            </div>
        </div>
    }

    @if (ShowAvailabilitySection)
    {
        <div class="sidebar-section">
            <h3>Доступність та тип</h3>
            <div class="sidebar-list">
                @if (AvailableCount > 0 && AvailableCount < Books.Count)
                {
                    <button class="filter-pill @(Filters.OnlyAvailable ? "filter-pill--active" : "")"
                            @onclick="ToggleAvailable">
                        <span>Тільки доступні</span>
                        <span>@AvailableCount</span>
                    </button>
                }

                @if (PhysicalCount > 0)
                {
                    <button class="filter-pill @(Filters.OnlyPhysical ? "filter-pill--active" : "")"
                            @onclick="TogglePhysical">
                        <span>Тільки фізичні</span>
                        <span>@PhysicalCount</span>
                    </button>
                }

                @if (DigitalCount > 0)
                {
                    <button class="filter-pill @(Filters.OnlyDigital ? "filter-pill--active" : "")"
                            @onclick="ToggleDigital">
                        <span>Тільки цифрові</span>
                        <span>@DigitalCount</span>
                    </button>
                }

                @if (RentedCount > 0)
                {
                    <button class="filter-pill @(Filters.OnlyRented ? "filter-pill--active" : "")"
                            @onclick="ToggleRented">
                        <span>В оренді / очікує повернення</span>
                        <span>@RentedCount</span>
                    </button>
                }

                @if (WithFileCount > 0)
                {
                    <button class="filter-pill @(Filters.OnlyWithFile ? "filter-pill--active" : "")"
                            @onclick="ToggleWithFile">
                        <span>З прикріпленим файлом</span>
                        <span>@WithFileCount</span>
                    </button>
                }
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public List<Book> Books { get; set; } = [];
    [Parameter] public CatalogFilters Filters { get; set; } = new();
    [Parameter] public EventCallback<CatalogFilters> FiltersChanged { get; set; }

    private List<(string Value, int Count)> FormatOptions =>
        Books
            .Select(GetFileFormat)
            .Where(format => !string.IsNullOrWhiteSpace(format) && format != "Без файлу")
            .GroupBy(format => format)
            .Select(group => (Value: group.Key, Count: group.Count()))
            .OrderBy(item => item.Value)
            .ToList();

    private List<(string Value, int Count)> CategoryOptions =>
        Books
            .Where(book => !string.IsNullOrWhiteSpace(book.Category))
            .GroupBy(book => book.Category.Trim())
            .Select(group => (Value: group.Key, Count: group.Count()))
            .OrderBy(item => item.Value)
            .ToList();

    private List<(string Value, int Count)> LanguageOptions =>
        Books
            .Where(book => !string.IsNullOrWhiteSpace(book.Language))
            .GroupBy(book => book.Language.Trim())
            .Select(group => (Value: group.Key, Count: group.Count()))
            .OrderBy(item => item.Value)
            .ToList();

    private List<string> YearOptions =>
        Books
            .Where(book => book.PublicationYear > 0)
            .Select(book => book.PublicationYear.ToString())
            .Distinct()
            .OrderByDescending(year => year)
            .ToList();

    private int AvailableCount => Books.Count(book => book.IsDigital || book.AvailableCopies > 0);
    private int DigitalCount => Books.Count(book => book.IsDigital);
    private int PhysicalCount => Books.Count(book => !book.IsDigital);
    private int RentedCount => Books.Count(book => book.Rentals?.Any(rental => rental.Status == RentalStatuses.Active || rental.Status == RentalStatuses.ReturnPending) == true || book.RentedByUserId.HasValue);
    private int WithFileCount => Books.Count(book => !string.IsNullOrWhiteSpace(book.FileId));

    private bool ShowAvailabilitySection =>
        Books.Count > 0
        && ((AvailableCount > 0 && AvailableCount < Books.Count)
            || PhysicalCount > 0
            || DigitalCount > 0
            || RentedCount > 0
            || WithFileCount > 0);

    private async Task OnSearchChanged(ChangeEventArgs e)
    {
        Filters.SearchQuery = e.Value?.ToString() ?? string.Empty;
        await FiltersChanged.InvokeAsync(Filters);
    }

    private async Task ToggleFormat(string format)
    {
        Toggle(Filters.SelectedFormats, format);
        await FiltersChanged.InvokeAsync(Filters);
    }

    private async Task ToggleYear(string year)
    {
        Toggle(Filters.SelectedYears, year);
        await FiltersChanged.InvokeAsync(Filters);
    }

    private async Task ToggleCategory(string category)
    {
        Toggle(Filters.SelectedCategories, category);
        await FiltersChanged.InvokeAsync(Filters);
    }

    private async Task ToggleLanguage(string language)
    {
        Toggle(Filters.SelectedLanguages, language);
        await FiltersChanged.InvokeAsync(Filters);
    }

    private async Task ToggleAvailable()
    {
        Filters.OnlyAvailable = !Filters.OnlyAvailable;
        await FiltersChanged.InvokeAsync(Filters);
    }

    private async Task ToggleDigital()
    {
        Filters.OnlyDigital = !Filters.OnlyDigital;

        if (Filters.OnlyDigital)
        {
            Filters.OnlyPhysical = false;
            Filters.OnlyRented = false;
        }

        await FiltersChanged.InvokeAsync(Filters);
    }

    private async Task TogglePhysical()
    {
        Filters.OnlyPhysical = !Filters.OnlyPhysical;

        if (Filters.OnlyPhysical)
        {
            Filters.OnlyDigital = false;
        }

        await FiltersChanged.InvokeAsync(Filters);
    }

    private async Task ToggleRented()
    {
        Filters.OnlyRented = !Filters.OnlyRented;

        if (Filters.OnlyRented)
        {
            Filters.OnlyDigital = false;
            Filters.OnlyPhysical = true;
        }

        await FiltersChanged.InvokeAsync(Filters);
    }

    private async Task ToggleWithFile()
    {
        Filters.OnlyWithFile = !Filters.OnlyWithFile;
        await FiltersChanged.InvokeAsync(Filters);
    }

    private async Task ResetFilters()
    {
        Filters = new CatalogFilters();
        await FiltersChanged.InvokeAsync(Filters);
    }

    private static void Toggle(List<string> list, string value)
    {
        if (list.Contains(value))
        {
            list.Remove(value);
        }
        else
        {
            list.Add(value);
        }
    }

    private static string GetFileFormat(Book book)
    {
        if (string.IsNullOrWhiteSpace(book.OriginalFileName))
        {
            return "Без файлу";
        }

        string extension = Path.GetExtension(book.OriginalFileName).Trim('.').ToUpperInvariant();
        return string.IsNullOrWhiteSpace(extension) ? "Файл" : extension;
    }
}
