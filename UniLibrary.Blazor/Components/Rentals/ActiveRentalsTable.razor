@using UniLibrary.Blazor.Helpers
@using UniLibrary.Blazor.Models.ViewModels

@if (Rows.Count == 0)
{
    <p class="text-muted">@EmptyText</p>
}
else
{
    <div class="table-responsive">
        <table class="table table-bordered align-middle">
            <thead>
                <tr>
                    <th>Книга</th>
                    <th>Читач</th>
                    <th>Email</th>
                    <th>Група</th>
                    <th>Видано</th>
                    <th>Повернути до</th>
                    <th>Хто видав</th>
                    <th>Дія</th>
                </tr>
            </thead>
            <tbody>
                @foreach (RentalListItem row in Rows)
                {
                    <tr>
                        <td>
                            @if (ShowBookLink)
                            {
                                <button class="btn btn-link p-0" @onclick="() => OpenBook.InvokeAsync(row.Book.Id)">
                                    @row.Book.Title
                                </button>
                            }
                            else
                            {
                                @row.Book.Title
                            }
                            <div class="text-muted small">@row.Book.Author</div>
                        </td>
                        <td>@row.Rental.FullName</td>
                        <td>@RentalUiHelper.DisplayText(row.Rental.Email)</td>
                        <td>@RentalUiHelper.DisplayText(row.Rental.ReaderGroup)</td>
                        <td>@RentalUiHelper.FormatDate(row.Rental.RentedAt)</td>
                        <td>@RentalUiHelper.FormatDate(row.Rental.DueAt)</td>
                        <td>@RentalUiHelper.DisplayText(row.Rental.IssuedByFullName)</td>
                        <td>
                            <button class="btn btn-sm btn-success"
                                    disabled="@IsBusy"
                                    @onclick="() => ReturnClicked.InvokeAsync(new RentalReturnCommand(row.Book.Id, row.Rental.RentalId))">
                                Повернено
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    [Parameter] public List<RentalListItem> Rows { get; set; } = [];
    [Parameter] public bool IsBusy { get; set; }
    [Parameter] public bool ShowBookLink { get; set; }
    [Parameter] public string EmptyText { get; set; } = "Активних видач не знайдено.";
    [Parameter] public EventCallback<int> OpenBook { get; set; }
    [Parameter] public EventCallback<RentalReturnCommand> ReturnClicked { get; set; }
}
