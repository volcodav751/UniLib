@page "/register"

@using UniLibrary.Blazor.Models
@using UniLibrary.Blazor.Services

@inject AuthApiService AuthApiService
@inject NavigationManager Navigation

<div class="register-page">
    <div class="register-card">

        <div class="register-header">
            <h1>Створення акаунта</h1>
            <p>Студентський акаунт активується одразу. Акаунт викладача стане доступним тільки після підтвердження адміністратором. Якщо в системі ще немає Admin, перший акаунт автоматично стане адміністратором.</p>
        </div>

        <EditForm Model="registerModel" OnValidSubmit="RegisterAsync">
            <DataAnnotationsValidator />

            <div class="form-group">
                <label>Повне ім'я</label>
                <InputText class="form-control"
                           @bind-Value="registerModel.FullName"
                           placeholder="Наприклад: Іван Петренко" />
                <ValidationMessage For="@(() => registerModel.FullName)" />
            </div>

            <div class="form-group">
                <label>Email</label>
                <InputText class="form-control"
                           @bind-Value="registerModel.Email"
                           placeholder="example@gmail.com" />
                <ValidationMessage For="@(() => registerModel.Email)" />
            </div>

            <div class="form-group">
                <label>Пароль</label>
                <InputText class="form-control"
                           type="password"
                           @bind-Value="registerModel.Password"
                           placeholder="Мінімум 6 символів" />
                <ValidationMessage For="@(() => registerModel.Password)" />
            </div>

            <div class="form-group">
                <label>Підтвердження пароля</label>
                <InputText class="form-control"
                           type="password"
                           @bind-Value="registerModel.ConfirmPassword"
                           placeholder="Повторіть пароль" />
                <ValidationMessage For="@(() => registerModel.ConfirmPassword)" />
            </div>

            <div class="form-group">
                <label>Тип користувача</label>
                <InputSelect class="form-control" @bind-Value="registerModel.Role">
                    <option value="Student">Учень / студент</option>
                    <option value="Teacher">Викладач</option>
                </InputSelect>
                <small class="text-muted">Викладач після реєстрації очікує підтвердження адміністратора. Адмін не створюється через звичайну форму, окрім першого акаунта в системі.</small>
            </div>

            <button class="register-button" type="submit" disabled="@isLoading">
                @(isLoading ? "Реєстрація..." : "Зареєструватися")
            </button>

            <button type="button" class="auth-link-button" @onclick="GoLogin">
                Уже є акаунт? Увійти
            </button>

            @if (!string.IsNullOrWhiteSpace(message))
            {
                <div class="message @(isSuccess ? "success" : "error")">
                    @message
                </div>
            }
        </EditForm>

    </div>
</div>

@code {
    private RegisterRequest registerModel = new();
    private string message = string.Empty;
    private bool isSuccess;
    private bool isLoading;

    private async Task RegisterAsync()
    {
        isLoading = true;
        message = string.Empty;
        isSuccess = false;

        var result = await AuthApiService.RegisterAsync(registerModel);

        isSuccess = result.Success;
        message = result.Message;

        if (result.Success && !result.RequiresApproval)
        {
            Navigation.NavigateTo("/catalog");
        }

        isLoading = false;
    }

    private void GoLogin()
    {
        Navigation.NavigateTo("/login");
    }
}
