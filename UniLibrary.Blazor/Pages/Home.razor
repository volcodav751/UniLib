@page "/"

@using UniLibrary.Blazor.Models
@using UniLibrary.Blazor.Helpers
@using UniLibrary.Blazor.Services

@inject NavigationManager Navigation
@inject AuthApiService AuthApiService

<PageTitle>UniLibrary</PageTitle>

<div class="home-shell">
    <section class="home-panel">
        <div class="home-panel__badge">UniLibrary</div>

        <h1>Електронна бібліотека університету</h1>

        <p class="home-panel__text">
            Каталог навчальних книг і матеріалів. Студенти можуть переглядати та шукати книги,
            а викладачі й адміністратори — додавати книги та оформлювати видачу в бібліотеці.
        </p>

        <div class="home-panel__actions">
            <button class="home-primary-button" @onclick="GoCatalog">
                Відкрити каталог
            </button>

            @if (currentUser is null)
            {
                <button class="home-secondary-button" @onclick="GoLogin">
                    Увійти
                </button>

                <button class="home-secondary-button" @onclick="GoRegister">
                    Реєстрація
                </button>
            }
            else
            {
                <button class="home-secondary-button" @onclick="GoProfile">
                    Мій профіль
                </button>

                @if (CanManageBooks)
                {
                    <button class="home-secondary-button" @onclick="GoRentals">
                        Видача книг
                    </button>
                }
            }
        </div>

        @if (currentUser is not null)
        {
            <div class="home-user-note">
                Ви увійшли як <strong>@currentUser.FullName</strong>. Роль: @UserRoleHelper.GetDisplayName(currentUser.Role).
            </div>
        }
    </section>
</div>

@code {
    private UserResponse? currentUser;

    private bool CanManageBooks =>
        UserRoleHelper.CanManageBooks(currentUser?.Role);

    protected override async Task OnInitializedAsync()
    {
        currentUser = await AuthApiService.GetCurrentUserAsync();
    }

    private void GoCatalog() => Navigation.NavigateTo("/catalog");
    private void GoLogin() => Navigation.NavigateTo("/login");
    private void GoRegister() => Navigation.NavigateTo("/register");
    private void GoProfile() => Navigation.NavigateTo("/profile");
    private void GoRentals() => Navigation.NavigateTo("/rentals");
}
