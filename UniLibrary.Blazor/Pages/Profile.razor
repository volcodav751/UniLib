@page "/profile"

@using Microsoft.JSInterop
@using UniLibrary.Blazor.Models
@using UniLibrary.Blazor.Models.ViewModels
@using UniLibrary.Blazor.Services

@inject AuthApiService AuthApiService
@inject BookApiService BookApiService
@inject NavigationManager Navigation
@inject IJSRuntime Js

<PageTitle>Профіль</PageTitle>

<div class="profile-page">
    <div class="profile-card">
        <div class="profile-page-header">
            <div class="profile-page-avatar">@AvatarLetter</div>
            <div>
                <h1>Профіль користувача</h1>
                <p>Інформація про поточний акаунт і JWT-сесію</p>
            </div>
        </div>

        @if (currentUser is null)
        {
            <div class="alert alert-warning">Ви ще не увійшли в акаунт.</div>
            <button class="btn btn-primary" @onclick="GoLogin">Перейти до входу</button>
        }
        else
        {
            <div class="profile-info-grid">
                <div class="profile-info-item">
                    <span>Ім'я</span>
                    <strong>@currentUser.FullName</strong>
                </div>

                <div class="profile-info-item">
                    <span>Email</span>
                    <strong>@currentUser.Email</strong>
                </div>

                <div class="profile-info-item">
                    <span>Роль</span>
                    <strong>@UserRoleHelper.GetDisplayName(currentUser.Role)</strong>
                </div>

                <div class="profile-info-item">
                    <span>ID користувача</span>
                    <strong>@currentUser.Id</strong>
                </div>
            </div>

            <div class="profile-actions">
                <button class="btn btn-outline-primary" @onclick="GoCatalog">Перейти до каталогу</button>

                @if (CanManageRentals)
                {
                    <button class="btn btn-outline-success" @onclick="GoRentals">Видача / повернення книг</button>
                }

                <button class="btn btn-outline-danger" @onclick="LogoutAsync">Вийти з акаунта</button>
            </div>

            <div class="mt-4">
                <h3>Мої видані книги</h3>

                @if (isLoadingBooks)
                {
                    <p class="text-muted">Завантаження виданих книг...</p>
                }
                else
                {
                    <UserRentalsTable Rows="myRentalRows" OpenBook="OpenBook" />
                }
            </div>
        }
    </div>

    @if (CanManageRentals)
    {
        <div class="profile-card">
            <div class="profile-page-header">
                <div class="profile-page-avatar admin-avatar">↩</div>
                <div>
                    <h2>Службова видача та повернення книг</h2>
                    <p>Працівник бібліотеки, викладач або адміністратор записує видачу і фіксує фактичне повернення книги</p>
                </div>
            </div>

            <StatusAlert Message="@returnStatusMessage" IsError="@returnIsError" />

            @if (isLoadingBooks)
            {
                <p class="text-muted">Завантаження активних видач...</p>
            }
            else
            {
                <ActiveRentalsTable Rows="activeRentalRows"
                                    IsBusy="isReturnActionBusy"
                                    EmptyText="Активних видач зараз немає."
                                    ReturnClicked="ReturnRentalAsync" />
            }
        </div>
    }

    @if (UserRoleHelper.IsAdmin(currentUser?.Role))
    {
        <div class="profile-card admin-card">
            <div class="profile-page-header">
                <div class="profile-page-avatar admin-avatar">A</div>
                <div>
                    <h2>Панель адміністратора</h2>
                    <p>Адмін може підтверджувати акаунти викладачів, переглядати та видаляти користувачів</p>
                </div>
            </div>

            <StatusAlert Message="@statusMessage" IsError="@isError" />

            @if (isLoadingUsers)
            {
                <p>Завантаження користувачів...</p>
            }
            else
            {
                <UserManagementTable Users="users"
                                     CurrentUserId="@(currentUser?.Id ?? 0)"
                                     IsBusy="isUserActionBusy"
                                     ApproveRequested="ApproveTeacherAsync"
                                     DeleteRequested="DeleteUserAsync" />
            }
        </div>
    }
</div>

@code {
    private UserResponse? currentUser;
    private List<UserResponse> users = [];
    private List<RentalListItem> myRentalRows = [];
    private List<RentalListItem> activeRentalRows = [];
    private bool isLoadingUsers;
    private bool isLoadingBooks;
    private bool isReturnActionBusy;
    private bool isUserActionBusy;
    private string? statusMessage;
    private bool isError;
    private string? returnStatusMessage;
    private bool returnIsError;

    private bool CanManageRentals => UserRoleHelper.CanManageBooks(currentUser?.Role);

    private string AvatarLetter => string.IsNullOrWhiteSpace(currentUser?.FullName)
        ? "?"
        : currentUser.FullName.Trim()[0].ToString().ToUpperInvariant();

    protected override async Task OnInitializedAsync()
    {
        currentUser = await AuthApiService.GetCurrentUserAsync();

        if (currentUser is null)
        {
            return;
        }

        await LoadBooksAndRentalsAsync();

        if (UserRoleHelper.IsAdmin(currentUser.Role))
        {
            await LoadUsersAsync();
        }
    }

    private async Task LoadUsersAsync()
    {
        isLoadingUsers = true;
        users = await AuthApiService.GetUsersAsync();
        isLoadingUsers = false;
    }

    private async Task LoadBooksAndRentalsAsync()
    {
        if (currentUser is null)
        {
            return;
        }

        isLoadingBooks = true;
        List<Book> books = await BookApiService.GetBooksAsync();
        myRentalRows = RentalUiHelper.BuildUserRentalRows(books, currentUser.Id);

        if (CanManageRentals)
        {
            List<Book> booksWithActiveRentals = await BookApiService.GetActiveRentalBooksAsync();
            activeRentalRows = RentalUiHelper.BuildActiveRentalRows(booksWithActiveRentals);
        }
        else
        {
            activeRentalRows.Clear();
        }

        isLoadingBooks = false;
    }

    private async Task ReturnRentalAsync(RentalReturnCommand command)
    {
        bool confirmed = await Js.InvokeAsync<bool>(
            "confirm",
            "Позначити книгу як фактично повернену до бібліотеки?"
        );

        if (!confirmed)
        {
            return;
        }

        isReturnActionBusy = true;
        var result = await BookApiService.StaffReturnBookAsync(command.BookId, command.RentalId);
        isReturnActionBusy = false;

        returnStatusMessage = result.Message;
        returnIsError = !result.Success;

        if (result.Success)
        {
            await LoadBooksAndRentalsAsync();
        }
    }

    private async Task ApproveTeacherAsync(UserResponse user)
    {
        bool confirmed = await Js.InvokeAsync<bool>(
            "confirm",
            $"Підтвердити акаунт викладача {user.FullName} ({user.Email})?"
        );

        if (!confirmed)
        {
            return;
        }

        isUserActionBusy = true;
        var result = await AuthApiService.ApproveTeacherAsync(user.Id);
        isUserActionBusy = false;

        statusMessage = result.Message;
        isError = !result.Success;

        if (result.Success)
        {
            await LoadUsersAsync();
        }
    }

    private async Task DeleteUserAsync(UserResponse user)
    {
        bool confirmed = await Js.InvokeAsync<bool>(
            "confirm",
            $"Видалити користувача {user.FullName} ({user.Email})?"
        );

        if (!confirmed)
        {
            return;
        }

        isUserActionBusy = true;
        var result = await AuthApiService.DeleteUserAsync(user.Id);
        isUserActionBusy = false;

        statusMessage = result.Message;
        isError = !result.Success;

        if (result.Success)
        {
            await LoadUsersAsync();
        }
    }

    private void GoLogin() => Navigation.NavigateTo("/login");
    private void GoCatalog() => Navigation.NavigateTo("/catalog");
    private void GoRentals() => Navigation.NavigateTo("/rentals");
    private void OpenBook(int id) => Navigation.NavigateTo($"/books/{id}");

    private async Task LogoutAsync()
    {
        await AuthApiService.LogoutAsync();
        Navigation.NavigateTo("/");
    }
}
