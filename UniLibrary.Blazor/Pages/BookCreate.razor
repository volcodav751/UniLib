@page "/books/create"

@using Microsoft.AspNetCore.Components.Forms
@using UniLibrary.Blazor.Models
@using UniLibrary.Blazor.Models.Requests
@using UniLibrary.Blazor.Services

@inject AuthApiService AuthApiService
@inject NavigationManager Navigation
@inject BookApiService BookApiService

<PageTitle>Додати книгу</PageTitle>

<h3>Додати книгу</h3>

@if (!string.IsNullOrWhiteSpace(StatusMessage))
{
    <div class="alert @(IsError ? "alert-danger" : "alert-success")">
        @StatusMessage
    </div>
}

@if (isCheckingAccess)
{
    <p>Перевірка доступу...</p>
}
else if (!canManageBooks)
{
    <div class="alert alert-danger">
        Додавати книги та файли може тільки викладач або адміністратор.
    </div>

    <button class="btn btn-primary" @onclick="GoLogin">
        Увійти
    </button>
}
else
{
    <EditForm Model="BookModel" OnValidSubmit="HandleSubmit">
        <div class="mb-3">
            <label class="form-label">Назва</label>
            <InputText class="form-control" @bind-Value="BookModel.Title" />
        </div>

        <div class="mb-3">
            <label class="form-label">Автор</label>
            <InputText class="form-control" @bind-Value="BookModel.Author" />
        </div>

        <div class="mb-3">
            <label class="form-label">Опис</label>
            <InputTextArea class="form-control" @bind-Value="BookModel.Description" />
        </div>

        <div class="mb-3">
            <label class="form-label">Категорія</label>
            <InputSelect class="form-select" @bind-Value="BookModel.Category">
                <option value="">Оберіть категорію</option>
                @foreach (var category in LibraryOptions.Categories)
                {
                    <option value="@category">@category</option>
                }
            </InputSelect>
            <div class="form-text">
                Категорія вибирається зі списку, щоб фільтр працював без різних варіантів написання.
            </div>
        </div>

        <div class="mb-3">
            <label class="form-label">Мова</label>
            <InputSelect class="form-select" @bind-Value="BookModel.Language">
                <option value="">Оберіть мову</option>
                @foreach (var language in LibraryOptions.Languages)
                {
                    <option value="@language">@language</option>
                }
            </InputSelect>
        </div>

        <div class="mb-3">
            <label class="form-label">Тип книги</label>
            <select class="form-select" @bind="BookType">
                <option value="Physical">Фізична книга — її можна орендувати</option>
                <option value="Digital">Цифрова книга — без оренди, тільки перегляд/скачування</option>
            </select>
            <div class="form-text">
                Оренда доступна тільки для фізичних книг. Для цифрових книг кнопка оренди не показується.
            </div>
        </div>

        @if (BookType == "Physical")
        {
            <div class="mb-3">
                <label class="form-label">Кількість копій</label>
                <InputNumber class="form-control" @bind-Value="BookModel.TotalCopies" />
                <div class="form-text">
                    Це кількість фізичних примірників у бібліотеці. Під час оренди доступних копій стає менше.
                </div>
            </div>

            <div class="form-check mb-3">
                <InputCheckbox class="form-check-input" @bind-Value="BookModel.IsAvailable" />
                <label class="form-check-label">Доступна для оренди одразу після створення</label>
            </div>
        }
        else
        {
            <div class="alert alert-secondary">
                Для цифрової книги копії та оренда не використовуються. Вона буде доступна онлайн, якщо прикріпити файл.
            </div>
        }

        <div class="mb-3">
            <label class="form-label">Видавництво</label>
            <InputText class="form-control" @bind-Value="BookModel.Publisher" />
        </div>

        <div class="mb-3">
            <label class="form-label">Рік публікації</label>
            <InputNumber class="form-control" @bind-Value="BookModel.PublicationYear" />
        </div>

        <div class="mb-3">
            <label class="form-label">Кількість сторінок</label>
            <InputNumber class="form-control" @bind-Value="BookModel.PageCount" />
        </div>

        <div class="mb-3">
            <label class="form-label">ISBN</label>
            <InputText class="form-control" @bind-Value="BookModel.Isbn" />
        </div>

        <div class="mb-3">
            <label class="form-label">Теги (через кому)</label>
            <InputText class="form-control" @bind-Value="TagsText" />
        </div>

        <div class="mb-3">
            <label class="form-label">URL обкладинки</label>
            <InputText class="form-control" @bind-Value="BookModel.CoverImageUrl" />
        </div>

        <div class="mb-3">
            <label class="form-label">Файл книги</label>
            <InputFile OnChange="HandleFileSelected" />
            <div class="form-text">
                Дозволено: PDF, DOC, DOCX, TXT, RTF, ODT. Скачування буде в оригінальному форматі, а передперегляд — у PDF.
            </div>
            @if (SelectedFile is not null)
            {
                <div class="form-text">
                    Обрано файл: @SelectedFile.Name (@(SelectedFile.Size / 1024) KB)
                </div>
            }
        </div>

        <button class="btn btn-primary" type="submit" disabled="@IsSaving">
            @(IsSaving ? "Збереження..." : "Додати книгу")
        </button>
    </EditForm>
}

@code {
    private CreateBookRequest BookModel = CreateEmptyBookModel();

    private string BookType = "Physical";
    private string TagsText = string.Empty;
    private IBrowserFile? SelectedFile;
    private string? StatusMessage;
    private bool IsError;
    private bool IsSaving;
    private bool canManageBooks;
    private bool isCheckingAccess = true;

    protected override async Task OnInitializedAsync()
    {
        canManageBooks = await AuthApiService.IsTeacherOrAdminAsync();
        isCheckingAccess = false;
    }

    private void HandleFileSelected(InputFileChangeEventArgs e)
    {
        SelectedFile = e.File;
    }

    private async Task HandleSubmit()
    {
        try
        {
            IsSaving = true;
            StatusMessage = null;
            IsError = false;

            BookModel.IsDigital = BookType == "Digital";

            if (BookModel.IsDigital)
            {
                BookModel.IsAvailable = true;
                BookModel.TotalCopies = 0;
            }

            if (!ValidateBookModel())
            {
                return;
            }

            BookModel.Title = BookModel.Title.Trim();
            BookModel.Author = BookModel.Author.Trim();
            BookModel.Description = BookModel.Description.Trim();
            BookModel.Publisher = BookModel.Publisher.Trim();
            BookModel.Isbn = BookModel.Isbn.Trim();
            BookModel.CoverImageUrl = BookModel.CoverImageUrl?.Trim();

            BookModel.Tags = TagsText
                .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .ToList();

            var createdBook = await BookApiService.CreateBookAsync(BookModel);

            if (createdBook is null)
            {
                IsError = true;
                StatusMessage = "Не вдалося створити книгу. Перевірте, чи ви увійшли як викладач або адмін, і чи вибрані правильні категорія та мова.";
                return;
            }

            if (SelectedFile is not null)
            {
                var uploadResult = await BookApiService.UploadBookFileAsync(createdBook.Id, SelectedFile);

                if (!uploadResult.Success)
                {
                    IsError = true;
                    StatusMessage = $"Книгу створено, але файл не завантажився. {uploadResult.Message}";
                    return;
                }

                StatusMessage = $"Книгу успішно додано. {uploadResult.Message}";
            }
            else
            {
                StatusMessage = "Книгу успішно додано.";
            }

            IsError = false;

            BookModel = CreateEmptyBookModel();
            BookType = "Physical";
            TagsText = string.Empty;
            SelectedFile = null;
        }
        catch (Exception ex)
        {
            IsError = true;
            StatusMessage = $"Помилка: {ex.Message}";
        }
        finally
        {
            IsSaving = false;
        }
    }

    private bool ValidateBookModel()
    {
        if (string.IsNullOrWhiteSpace(BookModel.Title))
        {
            IsError = true;
            StatusMessage = "Введіть назву книги.";
            return false;
        }

        if (string.IsNullOrWhiteSpace(BookModel.Author))
        {
            IsError = true;
            StatusMessage = "Введіть автора книги.";
            return false;
        }

        if (!LibraryOptions.IsAllowedCategory(BookModel.Category))
        {
            IsError = true;
            StatusMessage = "Оберіть категорію зі списку.";
            return false;
        }

        if (!LibraryOptions.IsAllowedLanguage(BookModel.Language))
        {
            IsError = true;
            StatusMessage = "Оберіть мову зі списку.";
            return false;
        }

        if (BookModel.PublicationYear < 1000 || BookModel.PublicationYear > DateTime.Now.Year + 1)
        {
            IsError = true;
            StatusMessage = "Вкажіть коректний рік публікації.";
            return false;
        }

        if (BookModel.PageCount < 0)
        {
            IsError = true;
            StatusMessage = "Кількість сторінок не може бути від'ємною.";
            return false;
        }

        if (!BookModel.IsDigital && BookModel.TotalCopies < 1)
        {
            IsError = true;
            StatusMessage = "Для фізичної книги потрібно вказати хоча б 1 копію.";
            return false;
        }

        return true;
    }

    private static CreateBookRequest CreateEmptyBookModel()
    {
        return new CreateBookRequest
        {
            IsAvailable = true,
            IsDigital = false,
            TotalCopies = 1
        };
    }

    private void GoLogin()
    {
        Navigation.NavigateTo("/login");
    }
}
