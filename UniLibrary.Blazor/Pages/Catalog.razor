@page "/catalog"
@using UniLibrary.Blazor.Models
@inject UniLibrary.Blazor.Services.BookApiService BookApiService
@inject UniLibrary.Blazor.Services.AuthApiService AuthApiService
@inject NavigationManager Navigation

<div class="catalog-page">
    @if (currentUser is null && !isLoading)
    {
        <div class="catalog-loading">
            Для перегляду каталогу потрібно увійти в акаунт.
            <br />
            <button class="btn btn-primary mt-3" @onclick="GoLogin">Увійти</button>
        </div>
    }
    else
    {
        <div class="catalog-layout">
            <CatalogSidebar Filters="@filters" FiltersChanged="OnFiltersChanged" />

            @if (isLoading)
            {
                <div class="catalog-loading">Завантаження книг...</div>
            }
            else if (!string.IsNullOrWhiteSpace(errorMessage))
            {
                <div class="catalog-loading">@errorMessage</div>
            }
            else
            {
                <FileGrid Books="@books" SearchQuery="@filters.SearchQuery" />
            }

            <AccountPanel />
        </div>
    }
</div>

@code {
    private UserResponse? currentUser;
    private List<Book> books = [];
    private CatalogFilters filters = new();
    private bool isLoading = true;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            currentUser = await AuthApiService.GetCurrentUserAsync();

            if (currentUser is null)
            {
                return;
            }

            books = await BookApiService.GetBooksAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Помилка завантаження: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private Task OnFiltersChanged(CatalogFilters updatedFilters)
    {
        filters = updatedFilters;
        StateHasChanged();
        return Task.CompletedTask;
    }

    private void GoLogin()
    {
        Navigation.NavigateTo("/login");
    }
}
