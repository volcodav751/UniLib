@page "/books/{Id:int}"

@using Microsoft.JSInterop
@using UniLibrary.Blazor.Models
@using UniLibrary.Blazor.Services
@using UniLibrary.Blazor.Helpers

@inject BookApiService BookApiService
@inject AuthApiService AuthApiService
@inject NavigationManager Navigation
@inject IJSRuntime Js

<PageTitle>Перегляд книги</PageTitle>

@if (!string.IsNullOrWhiteSpace(statusMessage))
{
    <div class="alert @(isError ? "alert-danger" : "alert-success")">
        @statusMessage
    </div>
}

@if (isLoading)
{
    <p>Завантаження...</p>
}
else if (Book is null)
{
    <div class="alert alert-warning">
        Книгу не знайдено або потрібно увійти в акаунт.
    </div>

    <button class="btn btn-primary" @onclick="GoLogin">
        Увійти
    </button>
}
else
{
    <h3>@Book.Title</h3>

    <p><strong>Автор:</strong> @Book.Author</p>
    <p><strong>Категорія:</strong> @Book.Category</p>
    <p><strong>Мова:</strong> @Book.Language</p>
    <p><strong>Рік:</strong> @Book.PublicationYear</p>
    <p><strong>Тип:</strong> @(Book.IsDigital ? "Цифрова книга" : "Фізична книга")</p>
    @if (!Book.IsDigital)
    {
        <p><strong>Копії:</strong> доступно @Book.AvailableCopies з @Book.TotalCopies</p>
    }
    <p><strong>Статус:</strong> @GetAvailabilityText(Book)</p>
    <p><strong>Опис:</strong> @Book.Description</p>

    @if (UserRoleHelper.IsAdmin(currentUser?.Role))
    {
        <div class="mb-3">
            <button class="btn btn-danger" @onclick="DeleteBookAsync">
                Видалити книгу
            </button>
        </div>
    }

    @if (!Book.IsDigital)
    {
        <div class="rental-card mb-3">
            <h4>Видача фізичної книги</h4>

            @if (CanManageRentals)
            {
                <div class="alert alert-secondary">
                    Видача і повернення фізичних книг оформлюються працівником бібліотеки, викладачем або адміністратором. Для нової видачі відкрийте службову сторінку.
                </div>

                <button class="btn btn-success mb-3" @onclick="GoRentals">
                    Перейти до видачі / повернення
                </button>
            }
            else if (MyActiveRental is not null)
            {
                <div class="alert alert-info">
                    Ця книга зараз записана на вас.
                    <br />Дата видачі: @RentalUiHelper.FormatDate(MyActiveRental.RentedAt)
                    <br />Повернути до: @RentalUiHelper.FormatDate(MyActiveRental.DueAt)
                    <br />Повернення зафіксує працівник бібліотеки після фактичного повернення книги.
                </div>
            }
            else
            {
                <div class="alert alert-secondary">
                    Щоб взяти цю фізичну книгу, потрібно звернутися до бібліотекаря. Він оформить видачу на сайті та вкаже ваші дані.
                </div>
            }

            @if (CanManageRentals && ActiveRentals.Count > 0)
            {
                <div class="mt-4">
                    <h5>Активні видачі цієї книги</h5>
                    <div class="table-responsive">
                        <table class="table table-bordered align-middle">
                            <thead>
                                <tr>
                                    <th>Читач</th>
                                    <th>Email</th>
                                    <th>Група</th>
                                    <th>Дата видачі</th>
                                    <th>Повернути до</th>
                                    <th>Хто видав</th>
                                    <th>Дія</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (BookRental rental in ActiveRentals)
                                {
                                    <tr>
                                        <td>@rental.FullName</td>
                                        <td>@RentalUiHelper.DisplayText(rental.Email)</td>
                                        <td>@RentalUiHelper.DisplayText(rental.ReaderGroup)</td>
                                        <td>@RentalUiHelper.FormatDate(rental.RentedAt)</td>
                                        <td>@RentalUiHelper.FormatDate(rental.DueAt)</td>
                                        <td>@RentalUiHelper.DisplayText(rental.IssuedByFullName)</td>
                                        <td>
                                            <button class="btn btn-sm btn-success"
                                                    disabled="@isRentalActionBusy"
                                                    @onclick="() => ReturnRentalAsync(rental.RentalId)">
                                                Позначити поверненою
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-secondary">
            Це цифрова книга, тому видача як фізичного примірника для неї не використовується. Її можна переглядати або скачати, якщо файл прикріплений.
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(Book.FileId))
    {
        <div class="mb-3">
            <a class="btn btn-primary"
               href="@downloadUrl"
               target="_blank">
                Скачати оригінальний файл
            </a>
        </div>

        <p class="text-muted">
            Оригінальний файл: @Book.OriginalFileName
        </p>

        @if (CanPreview(Book))
        {
            <h4>PDF-передперегляд</h4>

            <iframe src="@previewUrl"
                    style="width: 100%; height: 800px; border: 1px solid #ccc; border-radius: 8px;">
            </iframe>
        }
        else if (!string.IsNullOrWhiteSpace(Book.PreviewError))
        {
            <div class="alert alert-warning">
                PDF-передперегляд не створено: @Book.PreviewError
            </div>
        }
        else
        {
            <p class="text-muted">
                PDF-передперегляд для цього файлу ще не готовий. Можна скачати оригінальний файл.
            </p>
        }
    }
    else
    {
        <p class="text-muted">До цієї книги файл не прикріплено.</p>
    }
}

@code {
    [Parameter]
    public int Id { get; set; }

    private Book? Book;
    private UserResponse? currentUser;
    private string downloadUrl = string.Empty;
    private string previewUrl = string.Empty;
    private bool isLoading = true;
    private string? statusMessage;
    private bool isError;
    private bool isRentalActionBusy;

    private bool CanManageRentals => UserRoleHelper.CanManageBooks(currentUser?.Role);

    private List<BookRental> ActiveRentals => Book?.Rentals?
        .Where(RentalUiHelper.IsActiveOrPending)
        .OrderBy(rental => rental.DueAt)
        .ToList() ?? [];

    private BookRental? MyActiveRental => currentUser is null
        ? null
        : Book?.Rentals?.FirstOrDefault(rental => rental.UserId == currentUser.Id && RentalUiHelper.IsActiveOrPending(rental));

    protected override async Task OnInitializedAsync()
    {
        currentUser = await AuthApiService.GetCurrentUserAsync();

        if (currentUser is null)
        {
            isLoading = false;
            return;
        }

        await LoadBookAsync();
        isLoading = false;
    }

    private async Task LoadBookAsync()
    {
        Book = await BookApiService.GetBookByIdAsync(Id);

        if (Book is not null && !string.IsNullOrWhiteSpace(Book.FileId))
        {
            downloadUrl = await BookApiService.GetBookFileUrlAsync(Book.Id);
            previewUrl = await BookApiService.GetBookPreviewUrlAsync(Book.Id);
        }
    }

    private bool CanPreview(Book book)
    {
        return !string.IsNullOrWhiteSpace(book.PreviewFileId)
            || book.ContentType == "application/pdf"
            || book.OriginalFileName?.EndsWith(".pdf", StringComparison.OrdinalIgnoreCase) == true;
    }

    private async Task ReturnRentalAsync(int rentalId)
    {
        if (Book is null)
        {
            return;
        }

        bool confirmed = await Js.InvokeAsync<bool>(
            "confirm",
            $"Позначити книгу '{Book.Title}' як повернену?"
        );

        if (!confirmed)
        {
            return;
        }

        isRentalActionBusy = true;
        var result = await BookApiService.StaffReturnBookAsync(Book.Id, rentalId);
        isRentalActionBusy = false;

        statusMessage = result.Message;
        isError = !result.Success;

        if (result.Success && result.Book is not null)
        {
            Book = result.Book;
        }
    }

    private async Task DeleteBookAsync()
    {
        if (Book is null)
        {
            return;
        }

        bool confirmed = await Js.InvokeAsync<bool>(
            "confirm",
            $"Видалити книгу '{Book.Title}'?"
        );

        if (!confirmed)
        {
            return;
        }

        var result = await BookApiService.DeleteBookAsync(Book.Id);

        statusMessage = result.Message;
        isError = !result.Success;

        if (result.Success)
        {
            Navigation.NavigateTo("/catalog");
        }
    }

    private static string GetAvailabilityText(Book book)
    {
        if (book.IsDigital)
        {
            return "цифрова, доступна онлайн";
        }

        if (book.AvailableCopies > 0)
        {
            return $"доступна для видачі у бібліотеці, копій: {book.AvailableCopies} з {book.TotalCopies}";
        }

        bool hasOccupiedCopies = book.Rentals?.Any(RentalUiHelper.IsActiveOrPending) == true;
        return hasOccupiedCopies ? "усі копії видані читачам" : "недоступна";
    }

    private void GoLogin() => Navigation.NavigateTo("/login");
    private void GoRentals() => Navigation.NavigateTo("/rentals");
}
