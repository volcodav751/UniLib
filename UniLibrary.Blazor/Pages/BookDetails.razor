@page "/books/{Id:int}"

@using Microsoft.JSInterop
@using UniLibrary.Blazor.Models
@using UniLibrary.Blazor.Services

@inject BookApiService BookApiService
@inject AuthApiService AuthApiService
@inject NavigationManager Navigation
@inject IJSRuntime Js

<PageTitle>Перегляд книги</PageTitle>

@if (!string.IsNullOrWhiteSpace(statusMessage))
{
    <div class="alert @(isError ? "alert-danger" : "alert-success")">
        @statusMessage
    </div>
}

@if (isLoading)
{
    <p>Завантаження...</p>
}
else if (Book is null)
{
    <div class="alert alert-warning">
        Книгу не знайдено або потрібно увійти в акаунт.
    </div>

    <button class="btn btn-primary" @onclick="GoLogin">
        Увійти
    </button>
}
else
{
    <h3>@Book.Title</h3>

    <p><strong>Автор:</strong> @Book.Author</p>
    <p><strong>Категорія:</strong> @Book.Category</p>
    <p><strong>Мова:</strong> @Book.Language</p>
    <p><strong>Рік:</strong> @Book.PublicationYear</p>
    <p><strong>Тип:</strong> @(Book.IsDigital ? "Цифрова книга" : "Фізична книга")</p>
    @if (!Book.IsDigital)
    {
        <p><strong>Копії:</strong> доступно @Book.AvailableCopies з @Book.TotalCopies</p>
    }
    <p><strong>Статус:</strong> @GetAvailabilityText(Book)</p>
    <p><strong>Опис:</strong> @Book.Description</p>

    @if (currentUser?.Role == "Admin")
    {
        <div class="mb-3">
            <button class="btn btn-danger" @onclick="DeleteBookAsync">
                Видалити книгу
            </button>
        </div>
    }

    @if (!Book.IsDigital)
    {
        <div class="rental-card mb-3">
            <h4>Оренда фізичної книги</h4>

            @if (MyActiveRental is not null)
            {
                <div class="alert alert-info">
                    Книга орендована вами.
                    <br />Дата оренди: @FormatDate(MyActiveRental.RentedAt)
                    <br />Повернути до: @FormatDate(MyActiveRental.DueAt)
                </div>

                <button class="btn btn-outline-success" @onclick="RequestReturnBookAsync" disabled="@isRentalActionBusy">
                    @(isRentalActionBusy ? "Надсилання..." : "Подати запит на повернення")
                </button>
            }
            else if (MyPendingReturnRental is not null)
            {
                <div class="alert alert-warning">
                    Ви вже подали запит на повернення цієї книги.
                    <br />Запит створено: @FormatDate(MyPendingReturnRental.ReturnRequestedAt)
                    <br />Книга стане доступною після підтвердження викладачем або адміністратором.
                </div>
            }
            else if (Book.AvailableCopies > 0)
            {
                <p class="text-muted">
                    Доступно копій: @Book.AvailableCopies з @Book.TotalCopies. Після оренди кількість доступних копій зменшиться на 1.
                </p>

                <button class="btn btn-success" @onclick="RentBookAsync" disabled="@isRentalActionBusy">
                    @(isRentalActionBusy ? "Оформлення..." : "Орендувати книгу")
                </button>
            }
            else
            {
                <div class="alert alert-warning">
                    Зараз немає доступних копій цієї книги.
                </div>
            }

            @if (CanManageReturns && PendingReturnRentals.Count > 0)
            {
                <div class="mt-4">
                    <h5>Повернення, які очікують підтвердження</h5>
                    <div class="table-responsive">
                        <table class="table table-bordered align-middle">
                            <thead>
                                <tr>
                                    <th>Користувач</th>
                                    <th>Email</th>
                                    <th>Дата запиту</th>
                                    <th>Дія</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (BookRental rental in PendingReturnRentals)
                                {
                                    <tr>
                                        <td>@rental.FullName</td>
                                        <td>@rental.Email</td>
                                        <td>@FormatDate(rental.ReturnRequestedAt)</td>
                                        <td>
                                            <button class="btn btn-sm btn-success"
                                                    disabled="@isRentalActionBusy"
                                                    @onclick="() => ConfirmReturnBookAsync(rental.RentalId)">
                                                Підтвердити повернення
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }

            @if (CanManageReturns && ActiveRentals.Count > 0)
            {
                <div class="mt-4">
                    <h5>Активні оренди</h5>
                    <div class="table-responsive">
                        <table class="table table-bordered align-middle">
                            <thead>
                                <tr>
                                    <th>Користувач</th>
                                    <th>Email</th>
                                    <th>Дата оренди</th>
                                    <th>Повернути до</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (BookRental rental in ActiveRentals)
                                {
                                    <tr>
                                        <td>@rental.FullName</td>
                                        <td>@rental.Email</td>
                                        <td>@FormatDate(rental.RentedAt)</td>
                                        <td>@FormatDate(rental.DueAt)</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-secondary">
            Це цифрова книга, тому оренда для неї не використовується. Її можна переглядати або скачати, якщо файл прикріплений.
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(Book.FileId))
    {
        <div class="mb-3">
            <a class="btn btn-primary"
               href="@downloadUrl"
               target="_blank">
                Скачати оригінальний файл
            </a>
        </div>

        <p class="text-muted">
            Оригінальний файл: @Book.OriginalFileName
        </p>

        @if (CanPreview(Book))
        {
            <h4>PDF-передперегляд</h4>

            <iframe src="@previewUrl"
                    style="width: 100%; height: 800px; border: 1px solid #ccc; border-radius: 8px;">
            </iframe>
        }
        else if (!string.IsNullOrWhiteSpace(Book.PreviewError))
        {
            <div class="alert alert-warning">
                PDF-передперегляд не створено: @Book.PreviewError
            </div>
        }
        else
        {
            <p class="text-muted">
                PDF-передперегляд для цього файлу ще не готовий. Можна скачати оригінальний файл.
            </p>
        }
    }
    else
    {
        <p class="text-muted">До цієї книги файл не прикріплено.</p>
    }
}

@code {
    [Parameter]
    public int Id { get; set; }

    private Book? Book;
    private UserResponse? currentUser;
    private string downloadUrl = string.Empty;
    private string previewUrl = string.Empty;
    private bool isLoading = true;
    private string? statusMessage;
    private bool isError;
    private bool isRentalActionBusy;

    private bool CanManageReturns => currentUser?.Role == "Teacher" || currentUser?.Role == "Admin";

    private List<BookRental> ActiveRentals => Book?.Rentals?
        .Where(IsActiveRental)
        .OrderBy(rental => rental.DueAt)
        .ToList() ?? new List<BookRental>();

    private List<BookRental> PendingReturnRentals => Book?.Rentals?
        .Where(IsReturnPendingRental)
        .OrderBy(rental => rental.ReturnRequestedAt)
        .ToList() ?? new List<BookRental>();

    private BookRental? MyActiveRental => currentUser is null
        ? null
        : Book?.Rentals?.FirstOrDefault(rental => rental.UserId == currentUser.Id && IsActiveRental(rental));

    private BookRental? MyPendingReturnRental => currentUser is null
        ? null
        : Book?.Rentals?.FirstOrDefault(rental => rental.UserId == currentUser.Id && IsReturnPendingRental(rental));

    protected override async Task OnInitializedAsync()
    {
        currentUser = await AuthApiService.GetCurrentUserAsync();

        if (currentUser is null)
        {
            isLoading = false;
            return;
        }

        await LoadBookAsync();
        isLoading = false;
    }

    private async Task LoadBookAsync()
    {
        Book = await BookApiService.GetBookByIdAsync(Id);

        if (Book is not null && !string.IsNullOrWhiteSpace(Book.FileId))
        {
            downloadUrl = await BookApiService.GetBookFileUrlAsync(Book.Id);
            previewUrl = await BookApiService.GetBookPreviewUrlAsync(Book.Id);
        }
    }

    private bool CanPreview(Book book)
    {
        return !string.IsNullOrWhiteSpace(book.PreviewFileId)
            || book.ContentType == "application/pdf"
            || book.OriginalFileName?.EndsWith(".pdf", StringComparison.OrdinalIgnoreCase) == true;
    }

    private async Task RentBookAsync()
    {
        if (Book is null)
        {
            return;
        }

        isRentalActionBusy = true;
        var result = await BookApiService.RentBookAsync(Book.Id);
        isRentalActionBusy = false;

        statusMessage = result.Message;
        isError = !result.Success;

        if (result.Success && result.Book is not null)
        {
            Book = result.Book;
        }
    }

    private async Task RequestReturnBookAsync()
    {
        if (Book is null)
        {
            return;
        }

        bool confirmed = await Js.InvokeAsync<bool>(
            "confirm",
            $"Подати запит на повернення книги '{Book.Title}'?"
        );

        if (!confirmed)
        {
            return;
        }

        isRentalActionBusy = true;
        var result = await BookApiService.RequestReturnBookAsync(Book.Id);
        isRentalActionBusy = false;

        statusMessage = result.Message;
        isError = !result.Success;

        if (result.Success && result.Book is not null)
        {
            Book = result.Book;
        }
    }

    private async Task ConfirmReturnBookAsync(int rentalId)
    {
        if (Book is null)
        {
            return;
        }

        bool confirmed = await Js.InvokeAsync<bool>(
            "confirm",
            $"Підтвердити повернення книги '{Book.Title}'?"
        );

        if (!confirmed)
        {
            return;
        }

        isRentalActionBusy = true;
        var result = await BookApiService.ConfirmReturnBookAsync(Book.Id, rentalId);
        isRentalActionBusy = false;

        statusMessage = result.Message;
        isError = !result.Success;

        if (result.Success && result.Book is not null)
        {
            Book = result.Book;
        }
    }

    private async Task DeleteBookAsync()
    {
        if (Book is null)
        {
            return;
        }

        bool confirmed = await Js.InvokeAsync<bool>(
            "confirm",
            $"Видалити книгу '{Book.Title}'?"
        );

        if (!confirmed)
        {
            return;
        }

        var result = await BookApiService.DeleteBookAsync(Book.Id);

        statusMessage = result.Message;
        isError = !result.Success;

        if (result.Success)
        {
            Navigation.NavigateTo("/catalog");
        }
    }

    private static string GetAvailabilityText(Book book)
    {
        if (book.IsDigital)
        {
            return "цифрова, доступна онлайн";
        }

        if (book.AvailableCopies > 0)
        {
            return $"доступна для оренди, копій: {book.AvailableCopies} з {book.TotalCopies}";
        }

        bool hasOccupiedCopies = book.Rentals?.Any(rental => IsActiveRental(rental) || IsReturnPendingRental(rental)) == true;
        return hasOccupiedCopies ? "усі копії зайняті" : "недоступна";
    }

    private static bool IsActiveRental(BookRental rental)
    {
        return string.Equals(rental.Status, RentalStatuses.Active, StringComparison.OrdinalIgnoreCase);
    }

    private static bool IsReturnPendingRental(BookRental rental)
    {
        return string.Equals(rental.Status, RentalStatuses.ReturnPending, StringComparison.OrdinalIgnoreCase)
            || string.Equals(rental.Status, "PendingReturn", StringComparison.OrdinalIgnoreCase)
            || string.Equals(rental.Status, "ReturnRequested", StringComparison.OrdinalIgnoreCase)
            || string.Equals(rental.Status, "Pending", StringComparison.OrdinalIgnoreCase);
    }

    private static string FormatDate(DateTime? value)
    {
        return value.HasValue ? value.Value.ToLocalTime().ToString("dd.MM.yyyy HH:mm") : "—";
    }

    private void GoLogin()
    {
        Navigation.NavigateTo("/login");
    }
}
