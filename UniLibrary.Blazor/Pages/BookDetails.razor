@page "/books/{Id:int}"

@using Microsoft.JSInterop
@using UniLibrary.Blazor.Models
@using UniLibrary.Blazor.Services

@inject BookApiService BookApiService
@inject AuthApiService AuthApiService
@inject NavigationManager Navigation
@inject IJSRuntime Js

<PageTitle>Перегляд книги</PageTitle>

@if (Book is null)
{
    <p>Завантаження...</p>
}
else
{
    <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
        <div>
            <h3>@Book.Title</h3>
            <p class="text-muted mb-0">@Book.Author</p>
        </div>

        @if (isAdmin)
        {
            <button class="btn btn-danger" @onclick="DeleteBookAsync">
                Видалити книгу
            </button>
        }
    </div>

    @if (!string.IsNullOrWhiteSpace(StatusMessage))
    {
        <div class="alert @(IsError ? "alert-danger" : "alert-success")">
            @StatusMessage
        </div>
    }

    <p><strong>Автор:</strong> @Book.Author</p>
    <p><strong>Категорія:</strong> @Book.Category</p>
    <p><strong>Мова:</strong> @Book.Language</p>
    <p><strong>Рік:</strong> @Book.PublicationYear</p>
    <p><strong>Опис:</strong> @Book.Description</p>

    @if (!string.IsNullOrWhiteSpace(Book.FileId))
    {
        <div class="mb-3">
            <a class="btn btn-primary"
               href="@BookApiService.GetBookFileUrl(Book.Id)"
               target="_blank">
                Скачати файл
            </a>
        </div>

        @if (CanPreview(Book))
        {
            <h4>Передперегляд</h4>

            <iframe src="@BookApiService.GetBookPreviewUrl(Book.Id)"
                    style="width: 100%; height: 800px; border: 1px solid #ccc; border-radius: 8px;">
            </iframe>
        }
        else
        {
            <p class="text-muted">
                Передперегляд для цього типу файлу поки недоступний. Можна скачати файл.
            </p>
        }
    }
    else
    {
        <p class="text-muted">До цієї книги файл не прикріплено.</p>
    }
}

@code {
    [Parameter]
    public int Id { get; set; }

    private Book? Book;
    private bool isAdmin;
    private string? StatusMessage;
    private bool IsError;

    protected override async Task OnInitializedAsync()
    {
        Book = await BookApiService.GetBookByIdAsync(Id);
        isAdmin = await AuthApiService.IsAdminAsync();
    }

    private bool CanPreview(Book book)
    {
        return book.ContentType == "application/pdf"
            || book.OriginalFileName?.EndsWith(".pdf", StringComparison.OrdinalIgnoreCase) == true
            || book.ContentType == "text/plain"
            || book.OriginalFileName?.EndsWith(".txt", StringComparison.OrdinalIgnoreCase) == true;
    }

    private async Task DeleteBookAsync()
    {
        if (Book is null)
        {
            return;
        }

        bool confirmed = await Js.InvokeAsync<bool>(
            "confirm",
            $"Видалити книгу '{Book.Title}'?"
        );

        if (!confirmed)
        {
            return;
        }

        var result = await BookApiService.DeleteBookAsync(Book.Id);

        if (result.Success)
        {
            Navigation.NavigateTo("/catalog");
            return;
        }

        IsError = true;
        StatusMessage = result.Message;
    }
}
